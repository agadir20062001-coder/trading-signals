# ================================================================
# ملف البيئة — نموذج للنسخ
# انسخه: cp .env.example .env
# ⚠️ لا ترفع .env على GitHub أبداً
# ================================================================

# ----------------------------------------------------------------
# 1. نموذج الذكاء الاصطناعي — اختر واحداً
# ----------------------------------------------------------------
# Groq (موصى به — مجاني بدون بطاقة)
# احصل على المفتاح: https://console.groq.com
GROQ_API_KEY=gsk_ضع_مفتاحك_هنا

# OpenRouter (احتياطي — مجاني بحدود)
# احصل على المفتاح: https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-ضع_مفتاحك_هنا

LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------------
# 2. تيليغرام
# ----------------------------------------------------------------
# التوكن: من @BotFather → /newbot
TELEGRAM_BOT_TOKEN=ضع_توكن_البوت_هنا
# Chat ID: من @userinfobot أو @RawDataBot
TELEGRAM_CHAT_ID=ضع_chat_id_هنا

# ----------------------------------------------------------------
# 3. FRED — بيانات اقتصادية (مجاني)
# ----------------------------------------------------------------
# احصل على المفتاح: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=ضع_مفتاح_fred_هنا

# ----------------------------------------------------------------
# 4. مستودع الذاكرة الخاص (GitHub)
# ----------------------------------------------------------------
# أنشئ مستودعاً خاصاً باسم trading-memory على GitHub
# ثم أنشئ Personal Access Token بصلاحية Contents: Read & Write
# GitHub → Settings → Developer Settings → Fine-grained tokens
MEMORY_REPO_NAME=اسمك/trading-memory
MEMORY_REPO_TOKEN=ghp_xxxxxxxxxxxxxxxxxx

# ----------------------------------------------------------------
# 5. قوائم الرموز المراقبة
# ----------------------------------------------------------------
WATCH_STOCKS=NVDA,AAPL,TSLA,AMZN,MSFT
WATCH_CRYPTO=BTC/USDT,ETH/USDT,SOL/USDT
WATCH_FOREX=EURUSD=X,GBPUSD=X,USDJPY=X
WATCH_COMMODITIES=GC=F,CL=F,SI=F
WATCH_INDICES=^GSPC,^DJI,^IXIC

# ----------------------------------------------------------------
# 6. إعدادات النظام
# ----------------------------------------------------------------
CONSENSUS_THRESHOLD=4

# ----------------------------------------------------------------
# 7. الإيميل — تقرير مفصل عند كل إشارة (اختياري)
# ----------------------------------------------------------------
# Gmail: استخدم App Password (ليس كلمة مرور حسابك)
# كيفية إنشاء App Password:
# myaccount.google.com → الأمان → التحقق بخطوتين → كلمات مرور التطبيقات
EMAIL_FROM=بريدك@gmail.com
EMAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx
EMAIL_TO=المستلم@gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587

# Outlook/Hotmail
# EMAIL_SMTP_HOST=smtp.office365.com
# EMAIL_SMTP_PORT=587
